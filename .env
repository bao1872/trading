# 调度器配置
# 复制此文件为 .env 并根据需要修改配置

# 任务开关
ENABLE_DIVERGENCE_SCAN=true      # 背离扫描任务
ENABLE_DAILY_REPORT=false        # 日报生成任务
ENABLE_CLEANUP=true             # 临时文件清理任务

# 背离扫描配置
DIVERGENCE_SCAN_INTERVAL=5      # 扫描间隔（分钟）
DIVERGENCE_SCAN_START_HOUR=9    # 开始时间（小时）
DIVERGENCE_SCAN_END_HOUR=15     # 结束时间（小时）

# 日志配置
LOG_LEVEL=INFO                  # 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_FILE=scheduler.log         # 日志文件路径

# 通知配置（可选）
# FEISHU_WEBHOOK_URL=           # 飞书 webhook 地址
# FEISHU_SECRET=                # 飞书签名密钥
